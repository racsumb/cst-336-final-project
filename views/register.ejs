<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - <%= appName %></title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .auth-container { display: flex; justify-content: center; align-items: center; min-height: 80vh; }
        .auth-panel { max-width: 400px; width: 100%; text-align: center; }
    </style>
</head>
<body>
    <div id="pageBackground" class="page-bg"></div>
    <header>
        <h2>🛡️ <%= appName %></h2>
    </header>

    <main class="container auth-container">
        <section class="panel auth-panel">
            <h3>Create your account</h3>
            
            <form action="/api/register" method="POST">
                <div class="form-group">
                    <label style="text-align: left;">Account Name</label>
                    <input type="text" name="username" required>
                </div>
                
                <div class="form-group">
                    <label style="text-align: left;">Create a Password</label>
                    <input type="password" name="password" required>
                </div>
                
                <button type="submit" style="width: 100%;">Create Account</button>
            </form>
            
            <p style="margin-top: 1.5rem; color: #333333;">
                Already a hero? <a href="/" style="color: #1e90ff;">Return to login.</a>
            </p>
        </section>
    </main>
    <script src="/js/app.js"></script>
</body>
</html>