<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= appName %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div id="pageBackground" class="page-bg"></div>

    <%- include("partials/header", { user: user }) %>



    <div class="quote-banner">
        <h3 id="daily-quote">"Loading daily wisdom..."</h3>
    </div>

    <main class="container">
        <section class="panel">
            <h3>📊 Hero Stats</h3>
            <form id="stats-form">
                <input type="hidden" id="user-id" value="<%= userId %>">

                <div class="form-group">
                    <label>Sleep (Hours)</label>
                    <input type="number" id="sleep-input" name="sleep_hours" value="7.5" step="0.5" required>
                </div>

                <div class="form-group">
                    <label>Workout Time (Minutes)</label>
                    <input type="number" id="workout-input" name="workout_time" value="30" min="0" required>
                </div>

                <div class="form-group">
                    <label>Mood</label>
                    <input type="text" id="mood-input" name="mood" placeholder="e.g., Rested and Ready" required>
                </div>

                <button type="submit" id="update-stats-btn">Update Stats</button>
                <button id="view-stats-btn">View Stats History</button>
            </form>

        </section>

        <section class="panel">
            <h3>📜 Active Quests</h3>
            
            <div id="quest-list">
                <p style="color: #8b9eb7;">Loading your quests...</p>
            </div>
            
            <br>
            <button id="add-quest-btn">+ Add Custom Quest</button>
            <!-- <button id="random-workout-btn">🎲 Generate Random Quest</button> -->
        </section>
    </main>

    <div id="quest-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2>⚔️ New Quest</h2>
            <form id="new-quest-form">
                <label for="quest-title">Quest Name:</label>
                <input type="text" id="quest-title" name="quest-title" placeholder="e.g. Conquer the Gym" required>

                <label for="quest-category">Category:</label>
                <select id="quest-category" name="quest-category">
                    <option value="Fitness">Fitness</option>
                    <option value="Financial">Financial</option>
                    <option value="Productivity">Productivity</option>
                    <option value="Hobbies">Hobbies</option>
                    <option value="Learning">Learning</option>
                    <option value="Social">Social</option>
                </select>

                <label for="quest-difficulty">Difficulty:</label>
                <select id="quest-difficulty" name="quest-difficulty">
                    <option value="Easy">Easy (10 XP)</option>
                    <option value="Medium">Medium (25 XP)</option>
                    <option value="Hard">Hard (50 XP)</option>
                    <option value="Expert">Expert (100 XP)</option>
                </select>

                <div class="modal-actions">
                    <button type="submit" class="accept-btn">Accept Quest</button>
                    <button type="button" id="close-modal" class="cancel-btn">Abandon</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>