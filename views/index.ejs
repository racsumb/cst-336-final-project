<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= appName %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div id="pageBackground" class="page-bg"></div>

    <%- include("partials/header", { user: user }) %>



    <div class="quote-banner">
        <h3 id="daily-quote">"Loading daily wisdom..."</h3>
    </div>

    <main class="container">
        <section class="panel">
            <h3>📊 <span>Hero Stats</span></h3>
            <form id="stats-form">
                <input type="hidden" id="user-id" value="<%= userId %>">

                <div class="form-group">
                    <label>Sleep (Hours)</label>
                    <input type="number" id="sleep-input" name="sleep_hours" placeholder="Round to nearest half hour (e.g. 7.5)" step="0.5" required>
                </div>

                <div class="form-group">
                    <label>Workout Time (Minutes)</label>
                    <input type="number" id="workout-input" name="workout_time" placeholder ="Enter a whole number (e.g. 30)" min="0" required>
                </div>

                <div class="form-group">
                    <label>Mood</label>
                    <input type="text" id="mood-input" name="mood" placeholder="e.g., Rested and Ready" required>
                </div>

                <button type="submit" id="update-stats-btn">Update Stats</button>
                <button type="button" id="view-stats-btn">View Stats History</button>
            </form>

        </section>

        <section class="panel">
            <h3>📜 <span>Active Quests</span></h3>
            
            <div id="quest-list">
                <p style="color: #8b9eb7;">Loading your quests...</p>
            </div>
            
            <br>
            <button id="add-quest-btn">+ Add Quest</button>
            <!-- <button id="random-workout-btn">🎲 Generate Random Quest</button> -->
        </section>
    </main>

    <div id="quest-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2>⚔️ New Quest</h2>
            <form id="new-quest-form">
                <label for="quest-title">Quest Name:</label>
                <input type="text" id="quest-title" name="quest-title" placeholder="e.g. Conquer the Gym" required>

                <label for="quest-category">Category:</label>
                <select id="quest-category" name="quest-category">
                    <option value="Fitness">Fitness</option>
                    <option value="Financial">Financial</option>
                    <option value="Productivity">Productivity</option>
                    <option value="Hobbies">Hobbies</option>
                    <option value="Learning">Learning</option>
                    <option value="Social">Social</option>
                </select>

                <label for="quest-difficulty">Difficulty:</label>
                <select id="quest-difficulty" name="quest-difficulty">
                    <option value="Easy">Easy (10 XP)</option>
                    <option value="Medium">Medium (25 XP)</option>
                    <option value="Hard">Hard (50 XP)</option>
                    <option value="Expert">Expert (100 XP)</option>
                </select>

                <div class="modal-actions">
                    <button type="submit" class="accept-btn">Accept Quest</button>
                    <button type="button" id="close-modal" class="cancel-btn">Abandon</button>
                </div>
            </form>
        </div>
    </div>

    <div id="delete-quest-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="text-align: center;">
            <h3>🔥 Incinerate Quest?</h3>
            <p>Are you sure you want to incinerate this quest?</p>
            
            <div class="modal-actions" style="justify-content: center;">
                <button id="confirm-delete-btn" class="cancel-btn">Yes, Burn it</button>
                <button id="cancel-delete-btn" class="accept-btn">No, Keep it</button>
            </div>
        </div>
    </div>

    <div id="statsModal" class="modal-overlay">
        <div class="modal-content stats-large">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h3 id="stat-sheet-title">Stat Sheet</h3>
                    <button onclick="closeStatsModal()" class="close-modal-btn">❌</button>
                </div>

                <div id="today-banner" class="trend-card-full" style="margin: 1rem 0; border-radius: 4px;">
                    <h3 id="today-title">Today's Entry</h3>
                    <p id="today-details">Loading today's effort...</p>
                </div>

                <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                    <div class="trend-card-full">
                        <small>7-Day Sleep Avg</small>
                        <b id="sleep-avg-display">0h</b>
                    </div>
                    <div class="trend-card-full">
                        <small>7-Day Workout Avg</small>
                        <b id="work-avg-display">0m</b>
                    </div>
                </div>

                <div style="max-height: 250px; overflow-y: auto; border: 2px solid #8b7355; border-radius: 6px;">
                    <table class="stats-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Sleep</th>
                                <th>Workout</th>
                                <th>Mood</th>
                            </tr>
                        </thead>
                        <tbody id="history-table-body">
                        </tbody>
                    </table>
                </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>