<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= appName %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div id="pageBackground" class="page-bg"></div>
    <header>
        <h2>🛡️ <%= appName %></h2>
        <div>Level <%= playerLevel %> | XP: <%= playerXp %>/1000</div>
        <button id="logout-btn" style="background-color: transparent; border: 1px solid #d4af37; color: #d4af37; padding: 0.5rem 1rem;">Log Out</button>
    </header>

    <div class="quote-banner">
        <h3 id="daily-quote">"Loading daily wisdom..."</h3>
    </div>

    <main class="container">
        <section class="panel">
            <h3>📊 Hero Stats</h3>
            <form id="stats-form">
                
                <div class="form-group">
                    <label>Sleep (Hours)</label>
                    <input type="number" id="sleep-input" name="sleep_hours" value="7.5" step="0.5" required>
                </div>
                
                <div class="form-group">
                    <label>Workout Time (Minutes)</label>
                    <input type="number" id="workout-input" name="workout_time" value="30" min="0" required>
                </div>
                
                <div class="form-group">
                    <label>Mood</label>
                    <input type="text" id="mood-input" name="mood" placeholder="e.g., Rested and Ready" required>
                </div>
                
                <button type="submit" id="update-stats-btn">Update Stats</button>
                <button id="view-stats-btn">View Stats History</button>

            </form>
        </section>

        <section class="panel">
            <h3>📜 Active Quests</h3>
            
            <div id="quest-list">
                <div class="quest-item">
                    <label>
                        <input type="checkbox"> 30 Min Cardio (Hard - 50 XP)
                    </label>
                </div>
                <div class="quest-item">
                    <label>
                        <input type="checkbox" checked> Read 20 Pages (Easy - 15 XP)
                    </label>
                </div>
            </div>
            
            <br>
            <button id="add-quest-btn">+ Add Custom Quest</button>
            <button id="random-workout-btn">🎲 Generate Random Quest</button>
        </section>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>